apiVersion: eksctl.io/v1alpha5
kind: ClusterConfig

metadata:
  name: <<<clusterName>>>
  region: eu-central-1
  version: "<<<kubernetesVersion>>>"
  with-oidc: true
  support-type: Standard

vpc:
  subnets:
    private:
      eu-central-1b: { id: <<<subnetId1>>> }
      eu-central-1a: { id: <<<subnetId2>>> }

autoModeConfig:
  enabled: true

addons:
  # - name: vpc-cni
  # - name: coredns
  # - name: kube-proxy
  - name: aws-ebs-csi-driver
  - name: aws-efs-csi-driver
  # - name: eks-pod-identity-agent
  - name: external-dns
  # - name: metrics-server